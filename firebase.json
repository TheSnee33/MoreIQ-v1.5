{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "functions",
      "node_modules",
      ".git",
      "*.js",
      "!sw.js"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
